{
    "multipart": [
		{ "when": { "distance": 0 }, 
			"apply": { "model": "resprouted:block/grape_leaves_0" } },
		{ "when": { "distance": 0 }, 
			"apply": { "model": "resprouted:block/grape_stem_top" } },
		{ "when": { "distance": 1, "axis": "x" }, 
			"apply": { "model": "resprouted:block/grape_leaves_1", "y": 90 } },
		{ "when": { "distance": 1, "axis": "z" }, 
			"apply": { "model": "resprouted:block/grape_leaves_1" } },
		{ "when": { "axis": "x" }, 
			"apply": { "model": "resprouted:block/grape_vine", "y": 90 } },
		{ "when": { "axis": "z" }, 
			"apply": { "model": "resprouted:block/grape_vine" } },
		{ "when": { "has_grapes": "true" }, 
			"apply": { "model": "resprouted:block/grapes" } },
        { "when": { "axis": "x" }, 
			"apply": { "model": "resprouted:block/rope", "y": 90, "x": 90} },
        { "when": { "axis": "z" }, 
			"apply": { "model": "resprouted:block/rope", "x": 90 } }
    ]
}