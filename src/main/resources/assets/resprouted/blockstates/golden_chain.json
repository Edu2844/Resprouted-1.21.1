{
  "multipart": [
    {"when": {"axis": "y"},
      "apply": {"model": "resprouted:block/golden_chain"}},

    {"when": { "axis": "x"},
      "apply": {"model": "resprouted:block/golden_chain","x": 90,"y": 90}},

    {"when": {"axis": "z"},
      "apply": {"model": "resprouted:block/golden_chain","x": 90}},

    {"when": {"has_knot": "true"},
      "apply": {"model": "resprouted:block/golden_chain_knot"}}
  ]
}
